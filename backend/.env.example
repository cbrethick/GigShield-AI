# Backend Environment Variables (.env for local, Railway variables for production)

# The Database URL mapping for the PostgreSQL server
# Example: postgresql://username:password@host:port/dbname
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/gigshield

# Application URL
BACKEND_URL=http://localhost:8000

# Redis connection
REDIS_URL=redis://localhost:6379

# Razorpay Business Settings
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXX
RAZORPAYX_ACCOUNT_NUMBER=acc_XXXXXXXXXXXXXX

# Firebase Frontend Config
NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# Firebase Backend Config
FIREBASE_SERVICE_ACCOUNT_PATH=firebase-key.json

# Running mode - use "production" on Railway
ENVIRONMENT=development
